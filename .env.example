# Server Configuration
PORT=3000
HOST=127.0.0.1

# Chrome DevTools Protocol (CDP) Configuration
CDP_HOST=127.0.0.1
CDP_PORT=9000

# Antigravity Process
ANTIGRAVITY_PATH=antigravity
ANTIGRAVITY_PORT=9000

# Authentication
# Set AUTH_ENABLED=true to require password on the web interface
AUTH_ENABLED=false
AUTH_PASSWORD=changeme
# Generate a secure random secret with: openssl rand -hex 32
AUTH_SESSION_SECRET=change-this-to-a-random-secret-string
